# Copy to .env and fill in your own values (this file is committed; .env is git-ignored).

# Full URL of your Google Sheet (the spreadsheet ID is extracted from it automatically).
SHEET_URL="https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit"

# Path to your service-account key JSON (see useraccount.example.json for the shape).
SERVICE_ACCOUNT_FILE="./useraccount.json"
